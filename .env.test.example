# ── E2E Test Credentials Template ────────────────────────────────────────────
#
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local — it is gitignored.
#
# For GitHub Actions CI, add each variable as a Repository Secret at:
#   GitHub → Settings → Secrets and variables → Actions → New repository secret
#
# The test accounts below are pre-created in Supabase for E2E testing only.
# Do NOT use these accounts to store real business data.

# ── Supabase connection ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Sanity CMS ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=<project-id>
NEXT_PUBLIC_SANITY_DATASET=production

# ── Seller test account ───────────────────────────────────────────────────────
# Role: seller — can manage products, brand profile, respond to RFQs
# Supabase user ID: 101310ce-f48b-4f7c-84f2-0fa081b7c414
E2E_USER_EMAIL=e2e_seller@syndicate-test.dev
E2E_USER_PASSWORD=SyndicateE2E2026!
E2E_USER_ROLE=seller

# ── Buyer test account ────────────────────────────────────────────────────────
# Role: buyer — can browse, post RFQs, message sellers
# Supabase user ID: 3e2adc04-31f2-425f-8bf4-18d97768b6f1
E2E_BUYER_EMAIL=e2e_buyer@syndicate-test.dev
E2E_BUYER_PASSWORD=SyndicateE2E2026!
